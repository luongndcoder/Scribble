{
  "name": "scribble",
  "version": "1.0.0",
  "description": "Scribble — AI Meeting Notes",
  "main": "electron/main.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "electron:dev": "electron .",
    "electron:build": "electron-builder",
    "electron:build:win": "electron-builder --win",
    "electron:build:mac": "electron-builder --mac && npm rebuild better-sqlite3",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.0",
    "better-sqlite3": "^11.7.0",
    "cors": "^2.8.5",
    "docx": "^9.6.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "ffmpeg-static": "^5.2.0",
    "form-data": "^4.0.5",
    "formdata-node": "^6.0.3",
    "multer": "^1.4.5-lts.1",
    "openai": "^4.82.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0"
  }
}